% four corner macros
%
\NewDocumentCommand{\fcTailo}{m m m m m}{%
  \FourCornerFrame{#1}%
    {\csname SymbolTailo@#2\endcsname}%
    {\csname SymbolTailo@#3\endcsname}%
    {\csname SymbolTailo@#4\endcsname}%
    {\csname SymbolTailo@#5\endcsname}%
}%
