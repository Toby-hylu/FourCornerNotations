\NewDocumentCommand{\SyllableTailo}{O{} m}{\csname SyllableTailo@#2\endcsname{#1}}
\NewDocumentCommand{\fromTailo}{O{} m}{\raisebox{-.5em}[0pt][0pt]{\SyllableTailo[#1]{#2}}}
